{
  "name": "@wgalleti/primevue-components",
  "version": "0.3.1",
  "type": "module",
  "private": true,
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/primevue-components.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "yarn --cwd playground dev",
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist/types",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{vue,js,ts}\" --fix",
    "format": "prettier --write src/",
    "prepublishOnly": "yarn build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "axios": "^1.0.0",
    "dayjs": "^1.11.0",
    "primevue": "^4.2.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "maska": "^3.2.0"
  },
  "devDependencies": {
    "@primevue/themes": "^4.2.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.0",
    "prettier": "^3.4.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "workspaces": [
    "playground"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
